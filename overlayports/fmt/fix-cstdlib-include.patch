Add the missing <cstdlib> include (malloc/free). fmt defines
_LIBCPP_REMOVE_TRANSITIVE_INCLUDES, and libc++ 22 no longer provides
malloc/free transitively through the other headers. Fixed upstream in
fmt 12; this overlay stays on 11.x because folly 2024.08 still needs
the fmt/core.h -> fmt/format.h shim that fmt 12 removed.
--- a/include/fmt/format.h
+++ b/include/fmt/format.h
@@ -43,6 +43,7 @@
 #  include <cmath>    // std::signbit
 #  include <cstddef>  // std::byte
 #  include <cstdint>  // uint32_t
+#  include <cstdlib>  // std::malloc, std::free
 #  include <cstring>  // std::memcpy
 #  include <limits>   // std::numeric_limits
 #  include <new>      // std::bad_alloc
