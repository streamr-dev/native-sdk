[submodule "vcpkg"]
	path = vcpkg
	url = https://github.com/microsoft/vcpkg.git
	ignore = dirty
[submodule "packages/streamr-trackerless-network/test/integration/ts-integration"]
	path = packages/streamr-trackerless-network/test/integration/ts-integration
